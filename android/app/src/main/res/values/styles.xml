<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Tu splash personalizado -->
        <item name="android:windowBackground">@drawable/splash</item>

        <!-- DESACTIVA EL PREVIEW DE ANDROID 12+ (evita destello, pantalla negra, franja blanca) -->
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/black</item>
    </style>
</resources>
